<resources>
    <style name="Base.Theme.Vaulted" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowLightStatusBar">false</item>
        <item name="colorPrimary">@color/accent</item>
        <item name="colorOnSurface">@color/text_primary</item>
    </style>

    <style name="Theme.Vaulted" parent="Base.Theme.Vaulted" />

    <style name="Widget.Vaulted.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/surface_input</item>
        <item name="boxStrokeColor">@color/input_box_stroke</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="hintTextColor">@color/auth_tab_text</item>
        <item name="android:textColorHint">@color/text_secondary</item>
        <item name="endIconTint">@color/text_secondary</item>
    </style>

    <style name="Widget.Vaulted.TextInputEditText" parent="Widget.MaterialComponents.TextInputEditText.OutlinedBox">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorHint">@color/text_secondary</item>
        <item name="android:backgroundTint">@android:color/transparent</item>
    </style>
</resources>
